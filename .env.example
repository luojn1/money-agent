# 前端通过 Vite 代理访问后端时可留空
VITE_API_BASE_URL=
VITE_USE_MOCK_PIPELINE=false

# 后端监听端口
PORT=8080

# 单容器部署时由后端托管前端静态资源
SERVE_FRONTEND=true
RUNTIME_ROOT=/tmp/money-agent-runtime
PYTHON_BIN=/opt/venv/bin/python

# 前后端分域部署时配置，逗号分隔；同源部署可留空
CORS_ORIGIN=

# 报告内聊天默认使用本地规则模板，无需外部服务
DISABLE_CHAT=false
VITE_DISABLE_CHAT=false

# 仅在明确允许外部调用时启用；密钥只配置在后端环境
ENABLE_CHAT_LLM=false
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
